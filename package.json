{
  "name": "musclemovement",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "anatomy:fetch": "tools/fetch-source.sh",
    "anatomy:build": "node tools/build-anatomy.mjs .artifacts/anatomy-src && node tools/compress-anatomy.mjs && npm run anatomy:verify && npm run anatomy:stretch",
    "anatomy:verify": "node --import ./tools/lib/register-ts.mjs tools/verify-anatomy.mjs",
    "anatomy:calibrate": "node tools/calibrate-joints.mjs",
    "build:anatomy": "npm run anatomy:fetch && npm run anatomy:build",
    "anatomy:stretch": "node --import ./tools/lib/register-ts.mjs tools/measure-stretch.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "meshoptimizer": "^1.2.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
